<section class="hero-banner" style="background: linear-gradient(180deg, rgba(18,19,31,0.8) 0%, #12131f 100%), url('{{ section.settings.image | image_url: width: 1800 }}') center/cover no-repeat;">
  <div class="container" style="text-align: center; padding: 10rem 2rem;">
    <h1 class="luxury-heading" style="font-size: 3.5rem; margin-bottom: 1rem;">{{ section.settings.heading }}</h1>
    <p style="font-size: 1.2rem; max-width: 600px; margin: 0 auto 2.5rem auto; color: var(--text-light); opacity: 0.9;">{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.btn_link }}" class="btn-luxury" style="display: inline-flex; width: auto;">{{ section.settings.btn_text }}</a>
  </div>
</section>

<style>
.hero-banner {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
</style>

{% schema %}
{
  "name": "Luxury Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Editorial Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Generational Artistry"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading Copy",
      "default": "Curated exclusively for the business class. Crafted in Hyderabad."
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Label",
      "default": "Explore Creations"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Destination Link"
    }
  ],
  "presets": [
    {
      "name": "Luxury Hero Banner"
    }
  ]
}
{% endschema %}
