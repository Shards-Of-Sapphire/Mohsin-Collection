<div class="product-card" onclick="window.location.href='{{ product.url }}'">
  <div class="card-image-container">
    {% if product.featured_image %}
      {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'card-img' }}
    {% endif %}
  </div>
  <div class="card-info">
    <h3 class="card-title">{{ product.title }}</h3>
    <div class="card-price">{{ product.price | money_with_currency }}</div>
    <span class="card-action-text">View Valuation Specs →</span>
  </div>
</div>

<style>
.product-card {
  background: rgba(255, 255, 255, 0.01);
  border: 1px solid var(--border-subtle);
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  cursor: pointer;
  display: flex;
  flex-direction: column;
}
.product-card:hover {
  border-color: var(--text-gold-light);
  transform: translateY(-4px);
  background: rgba(255, 255, 255, 0.02);
}
.card-image-container {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: rgba(0,0,0,0.1);
}
.card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}
.product-card:hover .card-img {
  transform: scale(1.04);
}
.card-info {
  padding: 1.5rem;
}
.card-title {
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  color: var(--text-light);
  margin: 0 0 0.5rem 0;
  font-weight: 400;
  letter-spacing: 0.02em;
}
.card-price {
  color: var(--text-gold-light);
  font-size: 1.1rem;
  font-weight: 300;
  margin-bottom: 1rem;
}
.card-action-text {
  font-size: 0.75rem;
  text-transform: uppercase;
  color: var(--text-gold-dark);
  letter-spacing: 0.05em;
  font-weight: 600;
  transition: color 0.3s ease;
}
.product-card:hover .card-action-text {
  color: var(--text-gold-light);
}
</style>